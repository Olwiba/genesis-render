{
  "name": "@olwiba/genesis-render",
  "version": "0.0.7",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "olwibaUI adapter layer for @json-render — JSON-to-UI rendering for Genesis projects",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "web:build": "fumadocs-mdx && vite build",
    "web:dev": "fumadocs-mdx && vite dev",
    "start": "bun run server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:check": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "@olwiba/cn": "^0.1.15",
    "@olwiba/docs": "^0.1.25",
    "@olwiba/ui": "0.0.42"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@content-collections/mdx": "^0.2.2",
    "@olwiba/dx": "^0.0.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-start": "^1.168.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "fumadocs-core": "^16.4.7",
    "fumadocs-mdx": "^14.2.6",
    "fumadocs-ui": "^16.4.7",
    "jsdom": "^26.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.0",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0",
    "zod": "^3.24.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Olwiba/genesis-render"
  },
  "author": "Olwiba",
  "license": "MIT"
}
